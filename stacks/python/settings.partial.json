{
  "_comment": "source: stacks/python — deep-merged with core. Adds Python tooling allowlists (uv-first, pip/pipx fallback) and registers the ruff-format hook. Deny rules cover the package-manager footguns (pip install --user, --break-system-packages, --no-deps, --pre, publish to PyPI).",
  "permissions": {
    "allow": [
      "Bash(uv run:*)",
      "Bash(uv sync:*)",
      "Bash(uv add:*)",
      "Bash(uv remove:*)",
      "Bash(uv lock:*)",
      "Bash(uv pip list:*)",
      "Bash(uv pip show:*)",
      "Bash(uv pip freeze)",
      "Bash(uv pip install:*)",
      "Bash(uv tree:*)",
      "Bash(uv build:*)",
      "Bash(uv tool list)",
      "Bash(uv tool run:*)",
      "Bash(uv venv:*)",
      "Bash(uv python list)",
      "Bash(uv self version)",
      "Bash(pip list:*)",
      "Bash(pip show:*)",
      "Bash(pip freeze)",
      "Bash(pip check)",
      "Bash(pipx list)",
      "Bash(pipx run:*)",
      "Bash(pytest:*)",
      "Bash(coverage:*)",
      "Bash(ruff check:*)",
      "Bash(ruff format:*)",
      "Bash(ruff:*)",
      "Bash(black:*)",
      "Bash(isort:*)",
      "Bash(mypy:*)",
      "Bash(pyright:*)",
      "Bash(pyflakes:*)",
      "Bash(bandit:*)",
      "Bash(safety check:*)",
      "Bash(pip-audit:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(python -m:*)",
      "Bash(python3 -m:*)",
      "Bash(jupyter:*)",
      "Bash(ipython:*)",
      "Bash(poetry:*)",
      "Bash(hatch:*)"
    ],
    "deny": [
      "Bash(pip install:* --break-system-packages:*)",
      "Bash(pip install --user:*)",
      "Bash(pip install:* --no-deps:*)",
      "Bash(pip install:* --pre:*)",
      "Bash(pip install:* --upgrade:* --user)",
      "Bash(pip uninstall:*)",
      "Bash(uv pip install:* --break-system-packages:*)",
      "Bash(twine upload:*)",
      "Bash(python -m twine upload:*)",
      "Bash(uv publish:*)",
      "Bash(poetry publish:*)",
      "Bash(hatch publish:*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/ruff-format.sh"
          }
        ]
      }
    ]
  }
}
