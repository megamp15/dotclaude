{
  "_comment": "source: stacks/docker — deep-merged with core. Adds container-tooling allowlists and denies the most dangerous flags. Local-dev compose ops are allowed; production ops (push, login, system prune -a) are denied so the agent can't accidentally affect a registry or a shared volume cache.",
  "permissions": {
    "allow": [
      "Bash(docker build:*)",
      "Bash(docker buildx build:*)",
      "Bash(docker buildx ls)",
      "Bash(docker images:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(docker stats:*)",
      "Bash(docker version)",
      "Bash(docker info)",
      "Bash(docker network ls)",
      "Bash(docker network inspect:*)",
      "Bash(docker volume ls)",
      "Bash(docker volume inspect:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose run:*)",
      "Bash(docker compose config:*)",
      "Bash(docker compose pull:*)",
      "Bash(docker compose stop:*)",
      "Bash(docker compose start:*)",
      "Bash(docker compose restart:*)",
      "Bash(hadolint:*)",
      "Bash(dive:*)",
      "Bash(trivy image:*)",
      "Bash(trivy fs:*)"
    ],
    "deny": [
      "Bash(docker system prune -a:*)",
      "Bash(docker system prune --all:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker network prune:*)",
      "Bash(docker image prune -a:*)",
      "Bash(docker rm -f:*)",
      "Bash(docker kill:*)",
      "Bash(docker push:*)",
      "Bash(docker login:*)",
      "Bash(docker logout)",
      "Bash(docker run:* --privileged:*)",
      "Bash(docker run:* --pid=host:*)",
      "Bash(docker run:* --net=host:*)",
      "Bash(docker run:* --network=host:*)",
      "Bash(docker run:* -v /:*)",
      "Bash(docker run:* --volume /:*)",
      "Bash(docker run:* -v /var/run/docker.sock:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker compose down --volumes:*)",
      "Bash(docker swarm leave:*)",
      "Bash(docker stack rm:*)",
      "Bash(docker secret rm:*)",
      "Bash(docker config rm:*)"
    ]
  }
