{
  "_comment": "source: stacks/github-actions — permissions for GitHub CLI (gh) used to inspect workflows + runs + PRs and act on PRs/issues. No destructive gh operations allowed by default; mutating PR/issue ops are allowed because that's the daily-use surface (commenting, opening PRs). Repo-level destruction (delete repo/release/secret) is denied.",
  "permissions": {
    "allow": [
      "Bash(gh --version)",
      "Bash(gh auth status)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh repo clone:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr comment:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh pr merge:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue close:*)",
      "Bash(gh issue reopen:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh workflow run:*)",
      "Bash(gh workflow enable:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh run rerun:*)",
      "Bash(gh run download:*)",
      "Bash(gh api -X GET:*)",
      "Bash(gh api graphql:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh release download:*)",
      "Bash(gh secret list:*)",
      "Bash(gh variable list:*)",
      "Bash(gh search:*)",
      "Bash(gh label list:*)",
      "Bash(gh cache list:*)",
      "Bash(act -l:*)",
      "Bash(act --list:*)",
      "Bash(act -j:*)",
      "Bash(actionlint:*)"
    ],
    "deny": [
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh pr close:* --delete-branch:*)",
      "Bash(gh workflow disable:*)",
      "Bash(gh run cancel --all:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh variable set:*)",
      "Bash(gh variable delete:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release create:*)",
      "Bash(gh auth login:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth token:*)",
      "Bash(gh ssh-key add:*)",
      "Bash(gh gpg-key add:*)",
      "Bash(gh cache delete:*)",
      "Bash(gh api -X POST:*)",
      "Bash(gh api -X DELETE:*)",
      "Bash(gh api -X PUT:*)",
      "Bash(gh api -X PATCH:*)"
    ]
  }
}
