{
  "_comment": "source: stacks/docker — deep-merged with core. Adds container-tooling allowlists and denies the most dangerous flags.",
  "permissions": {
    "allow": [
      "Bash(docker build:*)",
      "Bash(docker buildx:*)",
      "Bash(docker images:*)",
      "Bash(docker ps:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(docker compose build:*)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose exec:*)",
      "Bash(docker compose config:*)"
    ],
    "deny": [
      "Bash(docker system prune -a:*)",
      "Bash(docker volume prune --all:*)",
      "Bash(docker rm -f:*)",
      "Bash(docker kill:*)",
      "Bash(docker push:*)",
      "Bash(docker login:*)",
      "Bash(docker run:* --privileged:*)",
      "Bash(docker compose down -v:*)"
    ]
  }
}
