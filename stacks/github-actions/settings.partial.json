{
  "_comment": "source: stacks/github-actions — permissions for GitHub CLI (gh) used to inspect workflows + runs + PRs. No destructive gh operations allowed by default.",
  "permissions": {
    "allow": [
      "Bash(gh auth status)",
      "Bash(gh repo view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr view*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr status*)",
      "Bash(gh pr create*)",
      "Bash(gh pr comment*)",
      "Bash(gh issue list*)",
      "Bash(gh issue view*)",
      "Bash(gh issue create*)",
      "Bash(gh issue comment*)",
      "Bash(gh workflow list*)",
      "Bash(gh workflow view*)",
      "Bash(gh workflow run*)",
      "Bash(gh run list*)",
      "Bash(gh run view*)",
      "Bash(gh run watch*)",
      "Bash(gh run rerun*)",
      "Bash(gh run download*)",
      "Bash(gh api *)",
      "Bash(gh release list*)",
      "Bash(gh release view*)",
      "Bash(gh secret list*)",
      "Bash(gh variable list*)",
      "Bash(act *)"
    ],
    "deny": [
      "Bash(gh repo delete*)",
      "Bash(gh pr close* --delete-branch*)",
      "Bash(gh workflow disable*)",
      "Bash(gh run cancel --all)",
      "Bash(gh secret delete*)",
      "Bash(gh secret set*)",
      "Bash(gh variable set*)",
      "Bash(gh variable delete*)",
      "Bash(gh release delete*)"
    ]
  }
}
