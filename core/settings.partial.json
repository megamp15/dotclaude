{
  "_comment": "source: core — universal permissions + hook registration. Deep-merged with stack settings.partial.json by dotclaude-init. The allow/deny philosophy mirrors Claude Code's auto-mode (https://www.anthropic.com/engineering/claude-code-auto-mode): broad allow for things that can't modify state OR are scoped to a known-safe tool; targeted deny for the destruction/exfiltration/escalation patterns that are dangerous regardless of context. The block-dangerous-commands.sh hook is the runtime safety net for everything the static rules can't catch.",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "_allow_groups": [
      "read-only inspection (pwd, ls, cat, tree, file, stat, du, df, env)",
      "git read-only (status, diff, log, show, branch -v, remote -v, rev-parse, blame, ls-files)",
      "gh read-only (auth status, repo view, pr view/list/diff/checks, run view/list, workflow view/list, issue view/list, api GET-shaped)",
      "find / search (find, grep, rg, fd, glob)",
      "process inspection (ps, top, jobs, which, type, command -v)",
      "network inspection (ping, dig, nslookup, host, traceroute)",
      "documentation tools (man, --help, -h, info)"
    ],
    "allow": [
      "Bash(pwd)",
      "Bash(ls:*)",
      "Bash(ll:*)",
      "Bash(la:*)",
      "Bash(tree:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(more:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(wc:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(env)",
      "Bash(printenv:*)",
      "Bash(date:*)",
      "Bash(uname:*)",
      "Bash(whoami)",
      "Bash(hostname)",
      "Bash(uptime)",
      "Bash(which:*)",
      "Bash(type:*)",
      "Bash(command -v:*)",
      "Bash(command -V:*)",
      "Bash(man:*)",
      "Bash(info:*)",
      "Bash(help:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(egrep:*)",
      "Bash(fgrep:*)",
      "Bash(rg:*)",
      "Bash(ag:*)",
      "Bash(fd:*)",
      "Bash(diff:*)",
      "Bash(jq:*)",
      "Bash(yq:*)",
      "Bash(awk:*)",
      "Bash(sed -n:*)",
      "Bash(cut:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tr:*)",
      "Bash(xxd:*)",
      "Bash(base64:*)",
      "Bash(md5sum:*)",
      "Bash(sha256sum:*)",
      "Bash(ps:*)",
      "Bash(top -b:*)",
      "Bash(htop:*)",
      "Bash(jobs)",
      "Bash(ping:*)",
      "Bash(dig:*)",
      "Bash(nslookup:*)",
      "Bash(host:*)",
      "Bash(traceroute:*)",
      "Bash(curl --version)",
      "Bash(wget --version)",
      "Bash(git status)",
      "Bash(git status:*)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch)",
      "Bash(git branch -v)",
      "Bash(git branch -vv)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git branch --show-current)",
      "Bash(git remote -v)",
      "Bash(git remote show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git blame:*)",
      "Bash(git stash list)",
      "Bash(git stash show:*)",
      "Bash(git tag)",
      "Bash(git tag -l:*)",
      "Bash(git fetch:*)",
      "Bash(gh --version)",
      "Bash(gh auth status)",
      "Bash(gh repo view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr status:*)",
      "Bash(gh issue list:*)",
      "Bash(gh issue view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh api -X GET:*)",
      "Bash(gh search:*)"
    ],
    "_deny_groups": [
      "destroy / exfiltrate (force push to protected, hard reset, rm -rf root, SQL DROP/TRUNCATE, mass cloud delete)",
      "degrade security posture (chmod 777, disable ssh keys check, modify .claude/settings.json from agent)",
      "cross trust boundaries (curl|sh, untrusted code execution, gh gist create with file content)",
      "bypass review or affect others (force push to main/master, --no-verify, --skip-checks, package publish)",
      "credential exfiltration (env-dump to network, ssh key copy out, .aws/.kube/.npmrc reads piped to curl)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git clean -fd:*)",
      "Bash(git clean -ffdx:*)",
      "Bash(git branch -D main:*)",
      "Bash(git branch -D master:*)",
      "Bash(git branch -D production:*)",
      "Bash(git branch -D release:*)",
      "Bash(git tag -d:*)",
      "Bash(git push origin --delete:*)",
      "Bash(git push --delete:*)",
      "Bash(git commit --no-verify:*)",
      "Bash(git push --no-verify:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(rm -rf /:*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf $HOME:*)",
      "Bash(rm -rf ${HOME}:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ./:*)",
      "Bash(rm -rf .git:*)",
      "Bash(rm -rf .claude:*)",
      "Bash(rm -rf node_modules:*)",
      "Bash(chmod 777:*)",
      "Bash(chmod -R 777:*)",
      "Bash(chmod 666:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(curl:* | zsh)",
      "Bash(wget:* | sh)",
      "Bash(wget:* | bash)",
      "Bash(wget:* | zsh)",
      "Bash(curl -X POST:* /etc/passwd:*)",
      "Bash(curl -X POST:* ~/.ssh:*)",
      "Bash(curl -X POST:* ~/.aws:*)",
      "Bash(curl -X POST:* ~/.kube:*)",
      "Bash(curl --upload-file:* ~/.ssh:*)",
      "Bash(curl --upload-file:* ~/.aws:*)",
      "Bash(scp ~/.ssh/:*)",
      "Bash(scp ~/.aws/:*)",
      "Bash(scp ~/.kube/:*)",
      "Bash(scp ~/.npmrc:*)",
      "Bash(cat ~/.ssh/id_rsa:*)",
      "Bash(cat ~/.ssh/id_ed25519:*)",
      "Bash(cat ~/.aws/credentials:*)",
      "Bash(cat ~/.kube/config:*)",
      "Bash(cat ~/.netrc:*)",
      "Bash(cat ~/.npmrc:*)",
      "Bash(cat ~/.pypirc:*)",
      "Bash(gh gist create:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh release delete:*)",
      "Bash(crontab -e:*)",
      "Bash(crontab -r:*)",
      "Bash(systemctl enable:*)",
      "Bash(systemctl disable:*)",
      "Bash(launchctl load:*)",
      "Bash(launchctl unload:*)",
      "Bash(echo:* >> ~/.ssh/authorized_keys:*)",
      "Bash(echo:* > ~/.ssh/authorized_keys:*)",
      "Bash(unset HISTFILE:*)",
      "Bash(set +o history:*)",
      "Bash(history -c:*)",
      "Write(.claude/settings.json)",
      "Write(.claude/settings.local.json)",
      "Write(~/.claude/settings.json)",
      "Edit(.claude/settings.json)",
      "Edit(.claude/settings.local.json)",
      "Edit(~/.claude/settings.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/block-dangerous-commands.sh"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-files.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/scan-secrets.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/warn-large-files.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/format-on-save.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-test.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/session-start.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/context-recovery.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/conductor-brief.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/notify.sh"
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/agent-team-idle.sh"
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/agent-team-task-completed.sh"
          }
        ]
      }
    ]
  }
}
